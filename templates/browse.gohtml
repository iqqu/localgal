{{ define "browse.gohtml" }}
{{ template "base_start" (dict "title" "Galleries") }}
  <h1>Galleries</h1>
  {{- if .Albums }}
    {{template "frag_pager_galleries.gohtml" .}}
    {{template "frag_gallery_tiles.gohtml" .}}
    {{template "frag_pager_galleries.gohtml" .}}
  {{- else }}
    <p class="muted">No galleries to show.</p>
  {{- end}}
{{template "base_end" .}}
{{end}}
