{{define "gallery_file_tags.gohtml"}}
{{if gt (len .FileTags) 0}}
  <h3>File Tags in Gallery</h3>
  <p class="chips">
    {{range .FileTags}}
      <a class="chip" href="/tag/{{.Name | urlquery}}">{{.Name}} ({{.Count}})</a>
    {{end}}
  </p>
{{else}}
  <h3>No File Tags in Gallery</h3>
{{end}}
{{end}}
